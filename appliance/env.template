# env.template — rendered to /opt/farmpos/.env by register-store.sh (envsubst).
# Combines non-secret store.yml identity with generated secrets. Never commit the
# rendered .env. All ${...} values are substituted at provision time.

# --- Identity (from store.yml) ---
STORE_ID=${STORE_ID}
STORE_NAME=${STORE_NAME}
STORE_TAGLINE=${STORE_TAGLINE}
STORE_LEGAL=${STORE_LEGAL}
STORE_SUBTITLE=${STORE_SUBTITLE}
APP_ENV=prod
TZ=${TZ}

# --- Image pin (from store.yml farmpos_version) ---
FARMPOS_VERSION=${FARMPOS_VERSION}
POS_IMAGE=${POS_IMAGE}

# --- Database (password generated per box) ---
POSTGRES_USER=farmstall
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=farmpos
DATABASE_URL=postgresql://farmstall:${POSTGRES_PASSWORD_URLENC}@postgres:5432/farmpos

# --- App secrets (generated per box) ---
SECRET_KEY=${SECRET_KEY}

# --- First admin (generated; force change on first login) ---
ADMIN_USER=admin
ADMIN_PASS=${ADMIN_PASS}

# --- Scale (from store.yml; blank = no scale) ---
SCALE_IP=${SCALE_IP}
SCALE_PORT=${SCALE_PORT}
