# Keep the POS image lean and free of secrets / unrelated code.
.git
.gitignore
.venv
__pycache__/
**/__pycache__/
*.pyc
.claude/

# The web shop is a separate image / optional per store - not part of the POS build.
ladycoleen_web/

# Recognition + Frigate are excluded from appliance boxes entirely.
recognition_service*.py
requirements_recognition.txt
RECOGNITION.md
frigate_config.yml

# Local certs / dev-only artefacts - never bake into an image.
cert.conf
cert.key
cert.pem
*.ps1
promote.ps1

# Installer tree is not part of the server image.
farm_pos_installer/
